  "card": {
    "log_id": "food_court_order_listing",
    "variables": [
      {
        "name": "activeTab",
        "type": "string",
        "value": "pending"
      },
      {
        "name": "pendingTabLabel",
        "type": "string",
        "value": "Pending (0)"
      },
      {
        "name": "completedTabLabel",
        "type": "string",
        "value": "Completed (0)"
      },
      {
        "name": "pendingCount",
        "type": "integer",
        "value": 0
      },
      {
        "name": "completedCount",
        "type": "integer",
        "value": 0
      },
      {
        "name": "pendingOrders",
        "type": "array",
        "value": []
      },
      {
        "name": "completedOrders",
        "type": "array",
        "value": []
      },
      {
        "name": "noPendingTitle",
        "type": "string",
        "value": "No Pending Orders"
      },
      {
        "name": "noPendingDescription",
        "type": "string",
        "value": "You don't have any pending orders right now. Explore our menu and place your first order!"
      },
      {
        "name": "noCompletedTitle",
        "type": "string",
        "value": "No Completed Orders"
      },
      {
        "name": "noCompletedDescription",
        "type": "string",
        "value": "You haven't completed any orders yet."
      },
      {
        "name": "exploreMenuLabel",
        "type": "string",
        "value": "Explore Menu"
      },
      {
        "name": "themeColor",
        "type": "string",
        "value": "#4FAF5A"
      }
    ],
    "states": [
      {
        "state_id": 0,
        "div": {
          "type": "container",
          "orientation": "vertical",
          "width": {
            "type": "match_parent"
          },
          "height": {
            "type": "match_parent"
          },
          "background": [
            {
              "type": "solid",
              "color": "#F6F8FA"
            }
          ],
          "items": [
            {
              "type": "container",
              "orientation": "horizontal",
              "width": {
                "type": "match_parent"
              },
              "height": {
                "type": "fixed",
                "value": 44
              },
              "background": [
                {
                  "type": "solid",
                  "color": "#FFFFFF"
                }
              ],
              "items": [
                {
                  "type": "container",
                  "orientation": "vertical",
                  "width": {
                    "type": "match_parent",
                    "weight": 1
                  },
                  "height": {
                    "type": "match_parent"
                  },
                  "content_alignment_horizontal": "center",
                  "content_alignment_vertical": "center",
                  "actions": [
                    {
                      "log_id": "switch_to_pending",
                      "url": "divaction://switch_tab?tab=pending"
                    }
                  ],
                  "items": [
                    {
                      "type": "text",
                      "text": "@{pendingTabLabel}",
                      "font_size": 14,
                      "font_weight": "@{activeTab == 'pending' ? 'bold' : 'medium'}",
                      "text_color": "@{activeTab == 'pending' ? themeColor : '#878787'}",
                      "text_alignment_horizontal": "center",
                      "width": {
                        "type": "wrap_content"
                      },
                      "height": {
                        "type": "wrap_content"
                      },
                      "font_family": "Roboto"
                    },
                    {
                      "type": "container",
                      "width": {
                        "type": "match_parent"
                      },
                      "height": {
                        "type": "fixed",
                        "value": 2
                      },
                      "margins": {
                        "top": 8
                      },
                      "alignment_vertical": "bottom",
                      "background": [
                        {
                          "type": "solid",
                          "color": "@{activeTab == 'pending' ? themeColor : '#00FFFFFF'}"
                        }
                      ],
                      "accessibility": {
                        "mode": "exclude"
                      }
                    }
                  ],
                  "accessibility": {
                    "type": "button",
                    "mode": "merge",
                    "description": "Pending orders tab"
                  }
                },
                {
                  "type": "container",
                  "orientation": "vertical",
                  "width": {
                    "type": "match_parent",
                    "weight": 1
                  },
                  "height": {
                    "type": "match_parent"
                  },
                  "content_alignment_horizontal": "center",
                  "content_alignment_vertical": "center",
                  "actions": [
                    {
                      "log_id": "switch_to_completed",
                      "url": "divaction://switch_tab?tab=completed"
                    }
                  ],
                  "items": [
                    {
                      "type": "text",
                      "text": "@{completedTabLabel}",
