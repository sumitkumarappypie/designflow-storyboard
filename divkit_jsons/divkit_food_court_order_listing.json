{
  "templates": {
    "pending_order_card": {
      "type": "container",
      "orientation": "vertical",
      "width": {
        "type": "match_parent"
      },
      "height": {
        "type": "wrap_content"
      },
      "background": [
        {
          "type": "solid",
          "color": "#FFFFFF"
        }
      ],
      "border": {
        "corner_radius": 16,
        "stroke": {
          "color": "#F0F0F0",
          "width": 1
        }
      },
      "margins": {
        "left": 16,
        "right": 16,
        "bottom": 12
      },
      "paddings": {
        "left": 16,
        "right": 16,
        "top": 16,
        "bottom": 16
      },
      "actions": [
        {
          "log_id": "open_pending_order",
          "url": "divaction://open_order_detail?orderId=@{item.getString('orderId')}"
        }
      ],
      "items": [
        {
          "type": "container",
          "orientation": "horizontal",
          "width": {
            "type": "match_parent"
          },
          "height": {
            "type": "wrap_content"
          },
          "content_alignment_vertical": "center",
          "items": [
            {
              "type": "image",
              "image_url": "@{item.getString('vendorImg')}",
              "width": {
                "type": "fixed",
                "value": 50
              },
              "height": {
                "type": "fixed",
                "value": 50
              },
              "border": {
                "corner_radius": 10
              },
              "placeholder_color": "#F0F0F0",
              "scale": "fill",
              "accessibility": {
                "type": "image",
                "description": "Photo of @{item.getString(\"vendorName\")}"
              }
            },
            {
              "type": "container",
              "orientation": "vertical",
              "width": {
                "type": "match_parent",
                "weight": 1
              },
              "height": {
                "type": "wrap_content"
              },
              "margins": {
                "left": 12
              },
              "items": [
                {
                  "type": "text",
                  "text": "@{item.getString('vendorName')}",
                  "font_size": 13,
                  "font_weight": "bold",
                  "text_color": "#101010",
                  "width": {
                    "type": "match_parent"
                  },
                  "height": {
                    "type": "wrap_content"
                  },
                  "max_lines": 1,
                  "ellipsis": {
                    "text": "..."
                  },
                  "font_family": "Roboto"
                },
                {
                  "type": "text",
                  "text": "@{item.getString('vendorAddress')}",
                  "font_size": 11,
                  "text_color": "#878787",
                  "width": {
                    "type": "match_parent"
                  },
                  "height": {
                    "type": "wrap_content"
                  },
                  "margins": {
                    "top": 2
                  },
                  "max_lines": 1,
                  "ellipsis": {
                    "text": "..."
                  },
                  "font_family": "Roboto"
                }
              ]
            }
          ]
        },
        {
          "type": "separator",
          "width": {
            "type": "match_parent"
          },
          "margins": {
            "top": 12,
            "bottom": 12
          },
          "delimiter_style": {
            "color": "#ECECFB"
          },
          "accessibility": {
            "mode": "exclude"
          }
        },
        {
          "type": "container",
          "orientation": "horizontal",
          "width": {
            "type": "match_parent"
          },
          "height": {
            "type": "wrap_content"
          },
          "items": [
            {
              "type": "text",
              "text": "@{item.getString('orderIdLabel')}",
              "font_size": 12,
              "text_color": "#878787",
              "width": {
                "type": "match_parent",
                "weight": 1
              },
              "height": {
                "type": "wrap_content"
              },
              "font_family": "Roboto"
            },
            {
              "type": "text",
              "text": "@{item.getString('displayOrderId')}",
              "font_size": 12,
              "font_weight": "medium",
              "text_color": "#101010",
              "width": {
                "type": "wrap_content"
              },
              "height": {
                "type": "wrap_content"
              },
              "font_family": "Roboto"
            }
          ]
        },
        {
          "type": "container",
          "orientation": "horizontal",
          "width": {
            "type": "match_parent"
          },
          "height": {
            "type": "wrap_content"
          },
          "margins": {
            "top": 8
          },
          "items": [
            {
              "type": "text",
              "text": "@{item.getString('orderDateLabel')}",
              "font_size": 12,
              "text_color": "#878787",
              "width": {
                "type": "match_parent",
                "weight": 1
              },
              "height": {
                "type": "wrap_content"
              },
              "font_family": "Roboto"
            },
            {
              "type": "text",
              "text": "@{item.getString('orderDate')}",
              "font_size": 12,
              "font_weight": "medium",
              "text_color": "#101010",
              "width": {
                "type": "wrap_content"
              },
              "height": {
                "type": "wrap_content"
              },
              "font_family": "Roboto"
            }
          ]
        },
        {
          "type": "container",
          "orientation": "horizontal",
          "width": {
            "type": "match_parent"
          },
          "height": {
            "type": "wrap_content"
          },
          "margins": {
            "top": 8
          },
          "items": [
            {
              "type": "text",
              "text": "@{item.getString('estimatedTimeLabel')}",
              "font_size": 12,
              "text_color": "#878787",
              "width": {
                "type": "match_parent",
                "weight": 1
              },
              "height": {
                "type": "wrap_content"
              },
              "font_family": "Roboto"
            },
            {
              "type": "text",
              "text": "@{item.getString('deliveryPickupTime')}",
              "font_size": 12,
              "font_weight": "medium",
              "text_color": "#101010",
              "width": {
                "type": "wrap_content"
              },
              "height": {
                "type": "wrap_content"
              },
              "font_family": "Roboto"
            }
          ]
        },
        {
          "type": "separator",
          "width": {
            "type": "match_parent"
          },
          "margins": {
            "top": 12,
            "bottom": 12
          },
          "delimiter_style": {
            "color": "#ECECFB"
          },
          "accessibility": {
            "mode": "exclude"
          }
        },
        {
          "type": "container",
          "orientation": "horizontal",
          "width": {
            "type": "match_parent"
          },
          "height": {
            "type": "wrap_content"
          },
          "content_alignment_vertical": "center",
          "items": [
            {
              "type": "text",
              "text": "@{item.getString('totalLabel')}",
              "font_size": 13,
              "font_weight": "bold",
              "text_color": "#101010",
              "width": {
                "type": "match_parent",
                "weight": 1
              },
              "height": {
                "type": "wrap_content"
              },
              "font_family": "Roboto"
            },
            {
              "type": "text",
              "text": "@{item.getString('totalPrice')}",
              "font_size": 13,
              "font_weight": "bold",
              "text_color": "@{themeColor}",
              "width": {
                "type": "wrap_content"
              },
              "height": {
                "type": "wrap_content"
              },
              "font_family": "Roboto"
            }
          ]
        },
        {
          "type": "container",
          "width": {
            "type": "match_parent"
          },
          "height": {
            "type": "fixed",
            "value": 40
          },
          "margins": {
            "top": 12
          },
          "content_alignment_horizontal": "center",
          "content_alignment_vertical": "center",
          "background": [
            {
              "type": "solid",
              "color": "@{themeColor}"
            }
          ],
          "border": {
            "corner_radius": 10
          },
          "visibility": "@{item.getString('whatsAppEnabled') == 'true' ? 'visible' : 'gone'}",
          "actions": [
            {
              "log_id": "send_whatsapp",
              "url": "divaction://send_whatsapp?number=@{item.getString('whatsAppNumber')}&message=@{item.getString('whatsAppMessage')}"
            }
          ],
          "items": [
            {
              "type": "container",
              "orientation": "horizontal",
              "width": {
                "type": "wrap_content"
              },
              "height": {
                "type": "wrap_content"
              },
              "content_alignment_vertical": "center",
              "items": [
                {
                  "type": "image",
                  "image_url": "https://raw.githubusercontent.com/FortAwesome/Font-Awesome/6.x/svgs/brands/whatsapp.svg",
                  "width": {
                    "type": "fixed",
                    "value": 16
                  },
                  "height": {
                    "type": "fixed",
                    "value": 16
                  },
                  "tint_color": "#FFFFFF",
                  "margins": {
                    "right": 8
                  },
                  "accessibility": {
                    "mode": "exclude"
                  }
                },
                {
                  "type": "text",
                  "text": "@{item.getString('whatsAppLabel')}",
                  "font_size": 13,
                  "font_weight": "medium",
                  "text_color": "#FFFFFF",
                  "width": {
                    "type": "wrap_content"
                  },
                  "height": {
                    "type": "wrap_content"
                  },
                  "font_family": "Roboto"
                }
              ]
            }
          ],
          "accessibility": {
            "type": "button",
            "mode": "merge",
            "description": "Send order on WhatsApp"
          }
        }
      ],
      "accessibility": {
        "type": "button",
        "mode": "merge",
        "description": "View pending order from @{item.getString(\"vendorName\")}"
      }
    },
